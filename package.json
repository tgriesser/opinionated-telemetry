{
  "name": "opinionated-telemetry",
  "version": "0.0.8",
  "description": "Opinionated OpenTelemetry: We've thought a lot about Telemetry in Node.js, so you don't have to",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./honeycomb": {
      "import": "./dist/esm/honeycomb.js",
      "require": "./dist/cjs/honeycomb.js",
      "types": "./dist/esm/honeycomb.d.ts"
    },
    "./metrics": {
      "import": "./dist/esm/metrics.js",
      "require": "./dist/cjs/metrics.js",
      "types": "./dist/esm/metrics.d.ts"
    },
    "./auto-instrument": {
      "import": "./dist/esm/auto-instrument.js",
      "require": "./dist/cjs/auto-instrument.js",
      "types": "./dist/esm/auto-instrument.d.ts"
    },
    "./auto-instrument-esm": {
      "import": "./dist/esm/auto-instrument-esm.js",
      "types": "./dist/esm/auto-instrument-esm.d.ts"
    },
    "./testing": {
      "import": "./dist/esm/testing.js",
      "require": "./dist/cjs/testing.js",
      "types": "./dist/esm/testing.d.ts"
    },
    "./integrations/knex": {
      "import": "./dist/esm/integrations/knex.js",
      "require": "./dist/cjs/integrations/knex.js",
      "types": "./dist/esm/integrations/knex.d.ts"
    },
    "./integrations/graphql": {
      "import": "./dist/esm/integrations/graphql.js",
      "require": "./dist/cjs/integrations/graphql.js",
      "types": "./dist/esm/integrations/graphql.d.ts"
    },
    "./integrations/bull": {
      "import": "./dist/esm/integrations/bull.js",
      "require": "./dist/cjs/integrations/bull.js",
      "types": "./dist/esm/integrations/bull.d.ts"
    },
    "./integrations/socket-io": {
      "import": "./dist/esm/integrations/socket-io.js",
      "require": "./dist/cjs/integrations/socket-io.js",
      "types": "./dist/esm/integrations/socket-io.d.ts"
    },
    "./integrations/express": {
      "import": "./dist/esm/integrations/express.js",
      "require": "./dist/cjs/integrations/express.js",
      "types": "./dist/esm/integrations/express.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "prebuild:cjs": "mkdir -p ./dist/cjs && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "format": "prettier --write '**/*.{ts,md,json}'",
    "format:check": "prettier --check '**/*.{ts,md,json}'",
    "lint": "eslint src/ test/",
    "lint:deps": "knip",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "test:watch": "vitest",
    "watch": "concurrently 'npm run build:cjs -- --watch' 'npm run build:esm -- --watch'"
  },
  "lint-staged": {
    "package.json": "sort-package-json",
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json}": "prettier --write"
  },
  "dependencies": {
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "husky": "^9.1.7",
    "knex": "^3.1.0",
    "knip": "^5.0.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sort-package-json": "^3.6.1",
    "supertest": "^7.2.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "engines": {
    "node": ">=20.15.0"
  }
}
